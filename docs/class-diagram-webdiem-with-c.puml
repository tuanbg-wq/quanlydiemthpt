'====================
' Quan he
'====================
VaiTro "1" -- "0..*" TaiKhoan : phan_quyen >
TaiKhoan "1" -- "0..*" LichSuMatKhau : doi_mat_khau >
TaiKhoan "1" -- "0..*" NhatKyHoatDong : tao_log >
TaiKhoan "1" -- "0..*" GiaoVien : lien_ket >

KhoaHoc "1" -- "0..*" LopHoc : gom >
KhoaHoc "1" -- "0..*" MonHoc : ap_dung >
NamHoc "1" -- "0..*" LopHoc : theo_nam >

GiaoVien "1" -- "0..*" LopHoc : chu_nhiem >
LopHoc "1" -- "0..*" HocSinh : chua >
HocSinh "1" -- "0..*" LichSuChuyenLop : lich_su >

GiaoVien "1" -- "0..*" MonHoc : phu_trach >
GiaoVien "1" -- "0..*" PhanCongGiangDay : day >
MonHoc "1" -- "0..*" PhanCongGiangDay : duoc_phan_cong >
LopHoc "1" -- "0..*" PhanCongGiangDay : duoc_hoc >
NamHoc "1" -- "0..*" PhanCongGiangDay : theo_nam >

GiaoVien "1" -- "0..*" VaiTroGV : duoc_gan >
LoaiVaiTroGV "1" -- "0..*" VaiTroGV : dinh_nghia >

HocSinh "1" -- "0..*" Diem : co >
MonHoc "1" -- "0..*" Diem : thuoc >
LoaiDiem "1" -- "0..*" Diem : phan_loai >
GiaoVien "1" -- "0..*" Diem : nhap >
NamHoc "1" -- "0..*" Diem : theo_nam >

HocSinh "1" -- "0..*" DiemTrungBinh : tong_hop >
MonHoc "1" -- "0..*" DiemTrungBinh : tong_hop >
NamHoc "1" -- "0..*" DiemTrungBinh : tong_hop >

HocSinh "1" -- "0..*" HanhKiem : xep_loai >
GiaoVien "1" -- "0..*" HanhKiem : danh_gia >
NamHoc "1" -- "0..*" HanhKiem : theo_nam >

HocSinh "1" -- "0..*" SuKienHanhKiem : phat_sinh >
NamHoc "1" -- "0..*" SuKienHanhKiem : theo_nam >
@enduml
