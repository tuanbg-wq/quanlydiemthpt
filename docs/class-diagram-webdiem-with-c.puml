@startuml
title Bieu do lop tong quat - He thong quan ly diem THPT (WebDiem)

'====================
' Cau hinh hien thi
'====================
skinparam linetype ortho
skinparam ArrowColor black
skinparam ArrowThickness 1.5
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam roundcorner 15
skinparam CircledCharacterRadius 9
skinparam CircledCharacterFontColor #1B4332
skinparam CircledCharacterBackgroundColor #B7E4C7

'====================
' Nhom tai khoan - bao mat
'====================
class VaiTro << (C,#B7E4C7) >> {
    - id_vai_tro : Int {PK}
    - ten_vai_tro : String
